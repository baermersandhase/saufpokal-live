{
  "routes": [
    {
      "route": "/",
      "rewrite": "/index.html"
    },
    {
      "route": "/tablet",
      "rewrite": "/tablet.html"
    },
    {
      "route": "/dashboard",
      "rewrite": "/dashboard.html"
    },
    {
      "route": "/admin",
      "rewrite": "/admin.html"
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/assets/*",
      "/*.css",
      "/*.js",
      "/*.png",
      "/*.jpg",
      "/*.svg",
      "/*.mp3"
    ]
  }
}
